{
  "name": "@core/draft-token",
  "description": "Utilities to sign and verify draft/preview tokens (e.g. for Contentful draft mode).",
  "author": "creativestyle GmbH",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "check-format": "prettier --check --ignore-unknown .",
    "check-lint": "eslint --max-warnings=0 .",
    "check-types": "tsc --noEmit",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint --max-warnings=0 --fix .",
    "setup": "npm run build"
  },
  "devDependencies": {
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*",
    "@types/node": "^22.10.7",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3"
  }
}
