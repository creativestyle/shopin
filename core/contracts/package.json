{
  "name": "@core/contracts",
  "description": "Shared TypeScript types, Zod schemas, and contracts used by BFF, presentation, and integrations.",
  "private": true,
  "scripts": {
    "check-types": "tsc --noEmit",
    "setup": "npm run build",
    "build": "tsc",
    "lint": "eslint --fix . --max-warnings=0",
    "format": "prettier --write --ignore-unknown .",
    "dev": "nodemon --watch src --ext ts --exec 'npm run build'"
  },
  "exports": {
    "./*": "./dist/*.js"
  },
  "devDependencies": {
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*",
    "nodemon": "^3.0.0",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@config/constants": "*",
    "zod": "^4.1.12"
  }
}
