{
  "name": "@apps/presentation",
  "version": "0.1.0",
  "description": "Next.js (App Router) storefront UI; consumes BFF for e-commerce and CMS content.",
  "author": "creativestyle GmbH",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev",
    "build": "next build",
    "build:e2e": "dotenv -e .env.e2e -- next build && cp -r public .next/standalone/apps/presentation/ && cp -r .next/static .next/standalone/apps/presentation/.next/",
    "start:local": "dotenv -e ../../.env -- next build && dotenv -e ../../.env -- next start",
    "start:e2e": "dotenv -e .env.e2e -- node .next/standalone/apps/presentation/server.js",
    "lint": "eslint --fix .",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@config/constants": "*",
    "@core/draft-token": "*",
    "@core/logger-config": "*",
    "@core/i18n": "*",
    "@demo/data-source-selector": "*",
    "@demo/demo-disclaimer": "*",
    "@demo/mocked-payment-service-provider": "*",
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-radio-group": "1.3.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.83.0",
    "@vitejs/plugin-react": "^4.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "imask": "^7.6.1",
    "next": "16.2.6",
    "next-intl": "^4.9.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.66.1",
    "react-imask": "^7.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "4.1.12",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "server-only": "^0.0.1"
  },
  "browserslist": [
    "chrome >= 110",
    "edge >= 110",
    "firefox >= 110",
    "safari >= 16",
    "not dead"
  ],
  "devDependencies": {
    "@core/contracts": "*",
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*",
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4",
    "@tanstack/eslint-plugin-query": "5.91.2",
    "@tanstack/react-query-devtools": "5.91.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.7.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.20.1",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-tailwindcss": "4.0.0-beta.0",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "prettier-plugin-tailwindcss": "0.7.1",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5",
    "vite": "8.0.8",
    "typescript-eslint": "^8.50.0"
  }
}
