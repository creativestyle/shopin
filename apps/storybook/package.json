{
  "name": "@apps/storybook",
  "description": "Storybook app for UI component documentation and development (Next.js integration).",
  "author": "creativestyle GmbH",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint --max-warnings=0 --fix .",
    "check-lint": "eslint --max-warnings=0 .",
