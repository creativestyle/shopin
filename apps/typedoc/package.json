    "dev": "concurrently \"nodemon --config nodemon.config.json\" \"vite  --config vite.config.ts\""
  },
  "devDependencies": {
    "@core/contracts": "*",
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*",
    "concurrently": "^10.0.3",
    "nodemon": "^3.1.9",
    "typedoc": "^0.27.9",
    "vite": "8.1.0"
  }
}
