{
  "name": "@apps/typedoc",
  "description": "Typedoc-generated API documentation site for SHOPin contracts and types.",
  "author": "creativestyle GmbH",
  "private": true,
  "scripts": {
    "test:unit": "vitest",
    "check-types": "tsc --noEmit",
    "build": "typedoc",
