{
  "name": "@integrations/commercetools-auth",
  "description": "NestJS module for Commercetools auth: login, register, logout, password reset, anonymous sessions, and email tokens",
  "private": true,
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "lint": "eslint --fix ./src --max-warnings=0",
    "format": "prettier --write ./src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@core/contracts": "*",
    "@integrations/commercetools-api": "*",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.3",
    "nestjs-pino": "^4.5.0"
  }
}
