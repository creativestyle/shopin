{
  "name": "@integrations/commercetools-api",
  "description": "NestJS module for Commercetools e-commerce API: catalog, cart, orders, customers, and service provider interface",
  "author": "creativestyle GmbH",
  "private": true,
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "build:all": "tsc --build tsconfig.json tsconfig.scripts.json",
    "dev": "tsc --build --watch",
    "setup:omnibus": "npm run build:all && dotenv -e ../../.env -- node dist/scripts/setup-omnibus-price.js",
    "lint": "eslint --fix ./src ./scripts --max-warnings=0",
    "format": "prettier --write ./src ./scripts",
    "format:check": "prettier --check --ignore-unknown ./src ./scripts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@commercetools/platform-sdk": "^8.13.0",
    "@commercetools/ts-client": "^4.1.0",
    "@core/contracts": "*",
    "@core/i18n": "*",
    "@config/constants": "*",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*",
    "@types/node": "^25.1.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2"
  }
}
