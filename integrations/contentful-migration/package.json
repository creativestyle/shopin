{
  "name": "@integrations/contentful-migration",
  "description": "Contentful CMS-as-code: migration scripts for content types (Page, teasers, layout) and optional demo content seed",
  "author": "creativestyle GmbH",
  "private": true,
  "scripts": {
    "build": "rm -rf dist && tsc",
    "migrate": "npm run build && dotenv -e ../../.env -- node dist/scripts/run-migrations.js",
    "lint": "eslint --fix . --max-warnings=0",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@core/typescript-config": "*",
    "commander": "14.0.3",
    "contentful-cli": "^3.4.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.20.1",
    "typescript": "5.7.3",
    "contentful-management": "^11.0.0",
    "@contentful/rich-text-types": "^16.6.1",
    "contentful-migration": "4.31.9"
  }
}
