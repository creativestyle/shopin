# =============================================================================
# SHOPin storefront accelerator – environment template
# =============================================================================
# Copy this file to .env and set values. Do not commit .env or real secrets.
# All variables are read from the repository root .env by BFF and presentation.
# =============================================================================

# -----------------------------------------------------------------------------
# BFF and frontend URLs (required for local development)
# -----------------------------------------------------------------------------
# BFF base URL including the /bff path. Used server-side by the Next.js app.
# Example (local): http://localhost:4000/bff
NEXT_BFF_INTERNAL_URL=

# Public BFF URL (embedded at build time; used by the browser and SSR).
# Example (local): http://localhost:4000/bff. Set in CI/Docker for production.
NEXT_PUBLIC_BFF_EXTERNAL_URL=

# Frontend origin for CORS. Must match the URL of the Next.js app.
# Example (local): http://localhost:3000
FRONTEND_URL=

# -----------------------------------------------------------------------------
# Logging (optional)
# -----------------------------------------------------------------------------
# Log level: trace | debug | info | warn | error | fatal. Used by BFF and presentation.
LOG_LEVEL=info

# When true, logs are pretty-printed for development. Use false in production.
LOG_PRETTY_PRINT=true

# -----------------------------------------------------------------------------
# BFF rate limiting (optional)
# -----------------------------------------------------------------------------
# Set to true to enable. When enabled, BFF_RATE_LIMIT_TTL and BFF_RATE_LIMIT_LIMIT are required.
BFF_RATE_LIMIT_ENABLED=true

# Global limit: time window in milliseconds and max requests per IP per window.
# Recommended: 100–200 for normal traffic.
BFF_RATE_LIMIT_TTL=60000
BFF_RATE_LIMIT_LIMIT=100

# Stricter limit for sensitive routes (auth, payment, order creation, password change).
BFF_RATE_LIMIT_SECURE_TTL=60000
BFF_RATE_LIMIT_SECURE_LIMIT=5

# -----------------------------------------------------------------------------
# Contentful (optional; required if using Contentful as CMS)
# -----------------------------------------------------------------------------
# Content Delivery API token. Secret; provide via CI/CD or secure config in production.
CONTENTFUL_ACCESS_TOKEN=

# Content Preview API token for draft content. Leave empty if you do not use preview.
# Secret; provide via CI/CD or secure config in production.
CONTENTFUL_PREVIEW_ACCESS_TOKEN=

# Contentful space ID and environment name (e.g. master).
CONTENTFUL_SPACE=
CONTENTFUL_ENVIRONMENT=master

# Secret for Next.js Draft Mode (/api/draft?secret=...). Set a strong random value.
# Secret; provide via CI/CD or secure config in production.
NEXT_DRAFT_MODE_SECRET=

# Management API token for Contentful migrations (CMS-as-code). Not the Delivery/Preview token.
# Create under Contentful: Profile → Personal access tokens. Used by integrations/contentful-migration.
CONTENTFUL_MANAGEMENT_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Commercetools (required when using commercetools-set data source)
# -----------------------------------------------------------------------------
# Create API credentials in your Commercetools project (API clients).
COMMERCETOOLS_CLIENT_ID=
COMMERCETOOLS_CLIENT_SECRET=
COMMERCETOOLS_PROJECT_KEY=
COMMERCETOOLS_API_URL=
COMMERCETOOLS_AUTH_URL=

# -----------------------------------------------------------------------------
# BFF security – token encryption and signing (required for auth and CSRF)
# -----------------------------------------------------------------------------
# Four base64-encoded 32-byte keys. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_ENCRYPTION_KEY=
JWT_SIGNING_KEY=
CSRF_TOKEN_ENCRYPTION_KEY=
CSRF_TOKEN_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Algolia (required for commercetools-algolia-set data source)
# -----------------------------------------------------------------------------
# Create an Algolia account and application at https://www.algolia.com/
# Grab keys from Settings → API Keys. Index is created manually in the dashboard.
# ALGOLIA_SEARCH_API_KEY needs at least: search, listIndexes ACLs.
# Add the "settings" ACL if you want facet metadata enrichment (display names);
# without it, search still works but facets use raw attribute names.
ALGOLIA_APP_ID=
ALGOLIA_SEARCH_API_KEY=
ALGOLIA_WRITE_API_KEY=
ALGOLIA_INDEX_NAME=
