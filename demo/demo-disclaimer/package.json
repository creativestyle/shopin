{
  "name": "@demo/demo-disclaimer",
  "version": "1.0.0",
  "description": "Demo-only modal dialog that warns visitors this is a sandbox environment with no real orders or payments.",
  "author": "creativestyle GmbH",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint --fix ./src --max-warnings=0",
