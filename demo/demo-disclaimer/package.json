    "format:check": "prettier --check --ignore-unknown ./src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-dialog": "1.1.15",
    "next-intl": "^4.5.8",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@core/typescript-config": "*",
    "@core/eslint-config": "*",
    "@core/prettier-config": "*",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3"
  }
}
