    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@config/constants": "*",
    "@core/typescript-config": "*",
    "@core/eslint-config": "*",
    "@core/prettier-config": "*"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "eslint": "^9.20.1",
    "typescript": "^5.7.3"
  }
}
